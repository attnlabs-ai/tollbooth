{
  "manifest_version": 3,
  "name": "Tollbooth",
  "version": "0.1.0",
  "description": "Add financial friction at checkout for selected categories.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tollbooth",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["categories.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["modal/modal.html", "modal/modal.css", "modal/modal.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
